enum SyncOperation {
  CREATE
  UPDATE
  DELETE

  @@schema("sync")
}

model SyncMutationLog {
  id               String        @id @default(uuid()) @db.Uuid
  mutation_id      String        @unique
  device_id        String
  user_id          String
  entity           String
  entity_id        String
  operation        SyncOperation
  payload          Json
  base_version     Int?
  client_timestamp DateTime
  server_timestamp DateTime      @default(now())

  @@map("mutation_log")
  @@schema("sync")
}

model SyncChangeLog {
  id               String        @id @default(uuid()) @db.Uuid
  cursor           BigInt        @unique @default(autoincrement())
  entity           String
  entity_id        String
  operation        SyncOperation
  data             Json
  server_version   Int
  server_timestamp DateTime      @default(now())

  @@index([cursor])
  @@map("change_log")
  @@schema("sync")
}
