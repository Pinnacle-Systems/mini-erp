{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -p none 'serwist build --watch' 'next dev'",
    "dev:once": "cross-env NODE_ENV=development serwist build && next dev",
    "build": "next build && serwist build",
    "start": "next start",
    "lint": "eslint",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:reset": "rimraf ./prisma/migrations && prisma migrate reset --force && prisma migrate dev --name init && prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@serwist/cli": "^9.5.6",
    "@serwist/next": "^9.5.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.10.13",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.0",
    "serwist": "^9.5.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
