# Keep this file in sync with apps/backend/.env.
# Keep cross-app values aligned with frontend env files too.
# PORT should match the port used in apps/frontend/.env VITE_DEV_PROXY_TARGET.
# DATABASE_URL is required by Prisma in prisma.config.ts and src/lib/prisma.ts.
# Backend startup and database access fail if this is missing or invalid.
DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/postgres"
# PORT is read in server.ts.
# If it is missing, the backend silently falls back to 3000.
PORT=3000
# JWT_SECRET signs and verifies auth tokens in src/shared/utils/token.utils.ts.
# Changing it invalidates existing access tokens.
JWT_SECRET=change-me
# CORS_ORIGIN is read in src/app.ts and accepts a comma-separated allowlist.
# If it is missing, the backend silently allows all origins.
CORS_ORIGIN=http://localhost:5173
# DEFAULT_BUSINESS_OWNER_PASSWORD is used when admin business creation auto-creates an owner.
# If it is missing, the code silently falls back to ChangeMe123!, so set this explicitly.
DEFAULT_BUSINESS_OWNER_PASSWORD=change-me-now
# NODE_ENV controls secure cookies and verbose error payloads.
# Use development locally and production behind HTTPS.
NODE_ENV=development
