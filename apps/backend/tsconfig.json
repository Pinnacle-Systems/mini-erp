{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "server.ts",
    "src/**/*.ts",
    "prisma.config.ts",
    "prisma/seed.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.test.ts",
    "vitest.config.ts"
  ]
}
