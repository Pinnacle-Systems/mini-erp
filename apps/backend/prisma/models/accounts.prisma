enum AccountType {
  ASSET // Cash, Inventory, Accounts Receivable
  LIABILITY // Loans, Accounts Payable
  EQUITY // Owner's investment
  REVENUE // Sales income
  EXPENSE // Rent, Salaries, COGS

  @@schema("accounts")
}

enum FinancialAccountType {
  CASH
  BANK
  UPI
  CREDIT_CARD
  OTHER

  @@schema("accounts")
}

enum MoneyMovementDirection {
  INFLOW
  OUTFLOW

  @@schema("accounts")
}

enum MoneyMovementStatus {
  POSTED
  VOIDED

  @@schema("accounts")
}

enum MoneyMovementSourceKind {
  PAYMENT_RECEIVED
  PAYMENT_MADE
  EXPENSE
  MANUAL

  @@schema("accounts")
}

enum FinancialDocumentType {
  SALES_INVOICE
  SALES_RETURN
  PURCHASE_INVOICE
  PURCHASE_RETURN

  @@schema("accounts")
}

model Account {
  id             String        @id @default(uuid()) @db.Uuid
  business_id    String        @db.Uuid
  name           String
  code           String // Chart of accounts
  type           AccountType
  ledger_entries LedgerEntry[]

  @@unique([business_id, code])
  @@map("accounts")
  @@schema("accounts")
}

model JournalEntry {
  id           String        @id @default(uuid()) @db.Uuid
  business_id  String        @db.Uuid
  description  String
  reference_id String?
  created_at   DateTime      @default(now())
  lines        LedgerEntry[]

  @@map("journal_entries")
  @@schema("accounts")
}

model LedgerEntry {
  id               String  @id @default(uuid()) @db.Uuid
  journal_entry_id String  @db.Uuid
  account_id       String  @db.Uuid
  party_id         String  @db.Uuid
  debit            Decimal @default(0) @db.Decimal(12, 2)
  credit           Decimal @default(0) @db.Decimal(12, 2)

  journal_entry JournalEntry @relation(fields: [journal_entry_id], references: [id])
  account       Account      @relation(fields: [account_id], references: [id])

  @@map("ledger_entries")
  @@schema("accounts")
}

model FinancialAccount {
  id              String               @id @default(uuid()) @db.Uuid
  business_id     String               @db.Uuid
  location_id     String?              @db.Uuid
  name            String
  account_type    FinancialAccountType
  currency        String               @default("INR") @db.VarChar(3)
  opening_balance Decimal              @default(0) @db.Decimal(12, 2)
  is_active       Boolean              @default(true)
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt
  archived_at     DateTime?
  money_movements MoneyMovement[]
  expenses        Expense[]

  @@unique([business_id, name])
  @@index([business_id, is_active])
  @@map("financial_accounts")
  @@schema("accounts")
}

model MoneyMovement {
  id                   String                 @id @default(uuid()) @db.Uuid
  business_id          String                 @db.Uuid
  direction            MoneyMovementDirection
  status               MoneyMovementStatus    @default(POSTED)
  source_kind          MoneyMovementSourceKind
  source_document_type FinancialDocumentType?
  source_document_id   String?                @db.Uuid
  occurred_at          DateTime
  amount               Decimal                @db.Decimal(12, 2)
  currency             String                 @default("INR") @db.VarChar(3)
  financial_account_id String                 @db.Uuid
  party_id             String?                @db.Uuid
  party_name_snapshot  String?
  location_id          String?                @db.Uuid
  reference_no         String?
  notes                String?
  reversed_by_id       String?                @db.Uuid
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt
  financial_account    FinancialAccount       @relation(fields: [financial_account_id], references: [id])
  allocations          MoneyMovementAllocation[]
  expenses             Expense[]

  @@index([business_id, occurred_at])
  @@index([business_id, direction, occurred_at])
  @@index([business_id, source_document_type, source_document_id])
  @@index([financial_account_id, occurred_at])
  @@map("money_movements")
  @@schema("accounts")
}

model MoneyMovementAllocation {
  id                String              @id @default(uuid()) @db.Uuid
  business_id       String              @db.Uuid
  money_movement_id String              @db.Uuid
  document_type     FinancialDocumentType
  document_id       String              @db.Uuid
  allocated_amount  Decimal             @db.Decimal(12, 2)
  created_at        DateTime            @default(now())
  money_movement    MoneyMovement       @relation(fields: [money_movement_id], references: [id], onDelete: Cascade)

  @@index([business_id, document_type, document_id])
  @@index([money_movement_id])
  @@map("money_movement_allocations")
  @@schema("accounts")
}

model ExpenseCategory {
  id          String    @id @default(uuid()) @db.Uuid
  business_id String    @db.Uuid
  name        String
  system_key  String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  archived_at DateTime?
  expenses    Expense[]

  @@unique([business_id, name])
  @@unique([business_id, system_key])
  @@index([business_id, is_active])
  @@map("expense_categories")
  @@schema("accounts")
}

model Expense {
  id                        String           @id @default(uuid()) @db.Uuid
  business_id               String           @db.Uuid
  occurred_at               DateTime
  amount                    Decimal          @db.Decimal(12, 2)
  currency                  String           @default("INR") @db.VarChar(3)
  payee_name                String
  party_id                  String?          @db.Uuid
  expense_category_id       String           @db.Uuid
  location_id               String?          @db.Uuid
  financial_account_id      String           @db.Uuid
  reference_no              String?
  notes                     String?
  money_movement_id         String           @db.Uuid
  external_reference_url    String?
  attachment_metadata       Json?
  created_at                DateTime         @default(now())
  updated_at                DateTime         @updatedAt
  expense_category          ExpenseCategory  @relation(fields: [expense_category_id], references: [id])
  financial_account         FinancialAccount @relation(fields: [financial_account_id], references: [id])
  money_movement            MoneyMovement    @relation(fields: [money_movement_id], references: [id])

  @@unique([money_movement_id])
  @@index([business_id, occurred_at])
  @@index([business_id, expense_category_id, occurred_at])
  @@map("expenses")
  @@schema("accounts")
}
