enum DocumentType {
  SALES_ESTIMATE
  PROFORMA_INVOICE
  SALES_ORDER
  DELIVERY_CHALLAN
  SALES_INVOICE
  SALES_RETURN

  PURCHASE_ORDER
  GOODS_RECEIPT_NOTE
  PURCHASE_INVOICE
  PURCHASE_RETURN

  @@schema("documents")
}

enum DocumentStatus {
  DRAFT
  OPEN
  PARTIAL
  COMPLETED
  EXPIRED
  CANCELLED
  VOID

  @@schema("documents")
}

enum DocumentCancelReason {
  CUSTOMER_DECLINED
  INTERNAL_DROP
  OTHER

  @@schema("documents")
}

enum DocumentHistoryEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  CONVERSION_LINKED

  @@schema("documents")
}

enum DocumentLineLinkType {
  FULFILLMENT
  RETURN

  @@schema("documents")
}

enum SettlementMode {
  CASH
  CREDIT

  @@schema("documents")
}

model Document {
  id                         String                @id @default(uuid()) @db.Uuid
  business_id                String                @db.Uuid
  type                       DocumentType
  status                     DocumentStatus        @default(DRAFT)
  cancel_reason              DocumentCancelReason?
  settlement_mode            SettlementMode?
  doc_number                 String
  created_at                 DateTime              @default(now())
  updated_at                 DateTime              @updatedAt
  posted_at                  DateTime?
  deleted_at                 DateTime?
  valid_until                DateTime?             @db.Date
  dispatch_date              DateTime?             @db.Date
  dispatch_carrier           String?
  dispatch_reference         String?
  location_id                String?               @db.Uuid
  location_name_snapshot     String?
  party_id                   String?               @db.Uuid
  party_snapshot             Json?
  parent_id                  String?               @db.Uuid
  parent                     Document?             @relation("DocHeirarchy", fields: [parent_id], references: [id])
  children                   Document[]            @relation("DocHeirarchy")
  currency                   String?               @db.VarChar(3)
  sub_total                  Decimal               @db.Decimal(12, 2)
  tax_total                  Decimal               @db.Decimal(12, 2)
  grand_total                Decimal               @db.Decimal(12, 2)
  notes                      String?
  shipping_addr              String?
  lineItems                  LineItem[]
  historyEntries             DocumentHistory[]

  @@unique([business_id, type, doc_number])
  @@map("documents")
  @@schema("documents")
}

model DocumentHistory {
  id                  String                   @id @default(uuid()) @db.Uuid
  business_id         String                   @db.Uuid
  document_id         String                   @db.Uuid
  event_type          DocumentHistoryEventType
  actor_user_id       String?                  @db.Uuid
  actor_name_snapshot String?
  from_status         DocumentStatus?
  to_status           DocumentStatus?
  metadata            Json?
  created_at          DateTime                 @default(now())
  document            Document                 @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id, created_at])
  @@index([business_id, created_at])
  @@map("document_history")
  @@schema("documents")
}

model LineItem {
  id                    String              @id @default(uuid()) @db.Uuid
  document_id           String              @db.Uuid
  item_id               String              @db.Uuid
  variant_id            String?             @db.Uuid
  description           String
  description_snapshot  String?
  item_name_snapshot    String?
  variant_name_snapshot String?
  sku_snapshot          String?
  barcode_snapshot      String?
  unit_snapshot         String?
  hsn_sac_snapshot      String?
  tax_mode_snapshot     String?
  option_values_snapshot Json?

  quantity     Decimal @db.Decimal(12, 3)
  unit_price   Decimal @db.Decimal(12, 2)
  tax_rate     Decimal @db.Decimal(5, 2)
  net_amount   Decimal? @db.Decimal(12, 2)
  tax_amount  Decimal? @db.Decimal(12, 2)
  gross_amount Decimal? @db.Decimal(12, 2)
  total        Decimal @db.Decimal(12, 2)

  document     Document             @relation(fields: [document_id], references: [id])
  source_links DocumentLineLink[]   @relation("DocumentLineLinkSource")
  target_links DocumentLineLink[]   @relation("DocumentLineLinkTarget")

  @@map("line_items")
  @@schema("documents")
}

model DocumentLineLink {
  id             String               @id @default(uuid()) @db.Uuid
  source_line_id String               @db.Uuid
  target_line_id String               @db.Uuid
  quantity       Decimal              @db.Decimal(12, 3)
  type           DocumentLineLinkType
  source_line    LineItem             @relation("DocumentLineLinkSource", fields: [source_line_id], references: [id], onDelete: Cascade)
  target_line    LineItem             @relation("DocumentLineLinkTarget", fields: [target_line_id], references: [id], onDelete: Cascade)

  @@index([source_line_id])
  @@index([target_line_id])
  @@index([source_line_id, type])
  @@map("document_line_links")
  @@schema("documents")
}
