enum DocumentType {
  SALES_ESTIMATE
  PROFORMA_INVOICE
  SALES_ORDER
  DELIVERY_CHALLAN
  SALES_INVOICE
  SALES_RETURN

  PURCHASE_ORDER
  GOODS_RECEIPT_NOTE
  PURCHASE_INVOICE
  PURCHASE_RETURN

  @@schema("documents")
}

enum DocumentStatus {
  DRAFT
  OPEN
  PARTIAL
  COMPLETED
  CANCELLED

  @@schema("documents")
}

model Document {
  id            String         @id @default(uuid()) @db.Uuid
  business_id   String         @db.Uuid
  type          DocumentType
  status        DocumentStatus @default(DRAFT)
  doc_number    String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  deleted_at    DateTime
  party_id      String         @db.Uuid
  parent_id     String?        @db.Uuid
  parent        Document?      @relation("DocHeirarchy", fields: [parent_id], references: [id])
  children      Document[]     @relation("DocHeirarchy")
  sub_total     Decimal        @db.Decimal(12, 2)
  tax_total     Decimal        @db.Decimal(12, 2)
  grand_total   Decimal        @db.Decimal(12, 2)
  notes         String?
  shipping_addr String?
  lineItems     LineItem[]

  @@unique([business_id, type, doc_number])
  @@map("documents")
  @@schema("documents")
}

model LineItem {
  id          String @id @default(uuid()) @db.Uuid
  document_id String @db.Uuid
  item_id     String @db.Uuid
  description String

  quantity   Decimal @db.Decimal(12, 3)
  unit_price Decimal @db.Decimal(12, 2)
  tax_rate   Decimal @db.Decimal(5, 2)
  total      Decimal @db.Decimal(12, 2)

  document Document @relation(fields: [document_id], references: [id])

  @@map("line_items")
  @@schema("documents")
}
