enum DocumentType {
  SALES_ESTIMATE
  PROFORMA_INVOICE
  SALES_ORDER
  DELIVERY_CHALLAN
  SALES_INVOICE
  SALES_RETURN

  PURCHASE_ORDER
  GOODS_RECEIPT_NOTE
  PURCHASE_INVOICE
  PURCHASE_RETURN

  @@schema("documents")
}

enum DocumentStatus {
  DRAFT
  OPEN
  PARTIAL
  COMPLETED
  CANCELLED

  @@schema("documents")
}

enum SalesTransactionType {
  CASH
  CREDIT

  @@schema("documents")
}

model Document {
  id                         String                @id @default(uuid()) @db.Uuid
  business_id                String                @db.Uuid
  type                       DocumentType
  status                     DocumentStatus        @default(DRAFT)
  transaction_type           SalesTransactionType?
  doc_number                 String
  created_at                 DateTime              @default(now())
  updated_at                 DateTime              @updatedAt
  posted_at                  DateTime?
  deleted_at                 DateTime?
  party_id                   String?               @db.Uuid
  parent_id                  String?               @db.Uuid
  parent                     Document?             @relation("DocHeirarchy", fields: [parent_id], references: [id])
  children                   Document[]            @relation("DocHeirarchy")
  customer_name_snapshot     String?
  customer_phone_snapshot    String?
  customer_address_snapshot  String?
  customer_tax_id_snapshot   String?
  currency                   String?               @db.VarChar(3)
  sub_total                  Decimal               @db.Decimal(12, 2)
  tax_total                  Decimal               @db.Decimal(12, 2)
  grand_total                Decimal               @db.Decimal(12, 2)
  notes                      String?
  shipping_addr              String?
  lineItems                  LineItem[]

  @@unique([business_id, type, doc_number])
  @@map("documents")
  @@schema("documents")
}

model LineItem {
  id                   String @id @default(uuid()) @db.Uuid
  document_id          String @db.Uuid
  item_id              String @db.Uuid
  variant_id           String? @db.Uuid
  description          String
  description_snapshot String?
  item_name_snapshot   String?
  variant_name_snapshot String?
  sku_snapshot         String?
  barcode_snapshot     String?
  unit_snapshot        String?
  hsn_sac_snapshot     String?
  tax_mode_snapshot    String?
  option_values_snapshot Json?

  quantity    Decimal @db.Decimal(12, 3)
  unit_price  Decimal @db.Decimal(12, 2)
  tax_rate    Decimal @db.Decimal(5, 2)
  net_amount  Decimal? @db.Decimal(12, 2)
  tax_amount  Decimal? @db.Decimal(12, 2)
  gross_amount Decimal? @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  document Document @relation(fields: [document_id], references: [id])

  @@map("line_items")
  @@schema("documents")
}
