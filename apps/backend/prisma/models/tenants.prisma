model Business {
  id         String        @id @default(uuid()) @db.Uuid
  name       String
  owner_id   String        @db.Uuid
  deleted_at DateTime?
  members    BusinessMember[]
  modules    BusinessModule[]

  @@map("businesses")
  @@schema("tenants")
}

model BusinessMember {
  id          String    @id @default(uuid()) @db.Uuid
  business       Business?    @relation(fields: [business_id], references: [id])
  business_id    String    @db.Uuid
  identity_id String    @db.Uuid
  role        BusinessRole @default(CASHIER)

  @@unique([business_id, identity_id])
  @@map("business_members")
  @@schema("tenants")
}

enum BusinessRole {
  OWNER
  MANAGER
  CASHIER

  @@schema("tenants")
}

enum BusinessModuleKey {
  CATALOG
  INVENTORY
  PRICING

  @@schema("tenants")
}

model BusinessModule {
  id         String         @id @default(uuid()) @db.Uuid
  business_id   String         @db.Uuid
  module_key BusinessModuleKey
  enabled    Boolean        @default(true)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  business      Business          @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@unique([business_id, module_key])
  @@index([business_id, enabled])
  @@map("business_modules")
  @@schema("tenants")
}
