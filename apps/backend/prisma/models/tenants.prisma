model Business {
  id                String           @id @default(uuid()) @db.Uuid
  name              String
  owner_id          String           @db.Uuid
  phone_number      String?
  gstin             String?
  email             String?
  business_type     String?
  business_category String?
  state             String?
  pincode           String?
  address           String?
  logo              String?
  deleted_at        DateTime?
  members           BusinessMember[]
  license           BusinessLicense?
  selected_sessions Session[]

  @@map("businesses")
  @@schema("tenants")
}

enum BusinessLicenseLimitType {
  MAX_USERS
  MAX_CONCURRENT_USERS

  @@schema("tenants")
}

model BusinessLicense {
  id                      String                    @id @default(uuid()) @db.Uuid
  business_id             String                    @unique @db.Uuid
  begins_at               DateTime
  ends_at                 DateTime
  bundle_key              BusinessBundleKey         @default(SALES_LITE)
  add_on_capability_keys  BusinessCapabilityKey[]   @default([])
  removed_capability_keys BusinessCapabilityKey[]   @default([])
  user_limit_type         BusinessLicenseLimitType?
  user_limit_value        Int?
  created_at              DateTime                  @default(now())
  updated_at              DateTime                  @updatedAt
  business                Business                  @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id, begins_at, ends_at])
  @@map("business_licenses")
  @@schema("tenants")
}

model BusinessMember {
  id          String       @id @default(uuid()) @db.Uuid
  business    Business?    @relation(fields: [business_id], references: [id])
  business_id String       @db.Uuid
  identity_id String       @db.Uuid
  role        BusinessRole @default(CASHIER)

  @@unique([business_id, identity_id])
  @@map("business_members")
  @@schema("tenants")
}

enum BusinessRole {
  OWNER
  MANAGER
  CASHIER

  @@schema("tenants")
}

enum BusinessBundleKey {
  SALES_LITE
  SALES_STOCK_OUT
  TRADING
  SERVICE_BILLING
  CUSTOM

  @@schema("tenants")
}

enum BusinessCapabilityKey {
  CATALOG_ITEMS
  CATALOG_SERVICES
  PARTIES_CUSTOMERS
  PARTIES_SUPPLIERS
  TXN_SALE_CREATE
  TXN_SALE_RETURN
  TXN_PURCHASE_CREATE
  TXN_PURCHASE_RETURN
  INV_STOCK_OUT
  INV_STOCK_IN
  INV_ADJUSTMENT
  INV_TRANSFER
  FINANCE_RECEIVABLES
  FINANCE_PAYABLES

  @@schema("tenants")
}
