enum UnitType {
  PCS
  UNIT
  SET
  PAIR
  PACK
  BOX
  CARTON
  BAGS
  BOTTLES
  CANS
  ROLL
  SHEET
  JOB
  VISIT
  SESSION
  HOUR
  DAY
  GRAM
  KG
  MILLILITRE
  LITRE
  MM
  CM
  M
  FEET
  INCH

  @@schema("catalog")
}

enum ItemType {
  PRODUCT
  SERVICE

  @@schema("catalog")
}

model Item {
  id          String        @id @default(uuid()) @db.Uuid
  business_id String        @db.Uuid
  item_type   ItemType      @default(PRODUCT)
  // Active item names are enforced unique per business by a partial unique index in SQL migrations.
  name        String
  hsn_sac     String?
  category    String?
  metadata    Json?
  unit        UnitType      @default(PCS)
  is_active   Boolean       @default(true)
  deleted_at  DateTime?
  variants    ItemVariant[]
  options     ItemOption[]

  @@map("items")
  @@schema("catalog")
}

model ItemCategory {
  id          String   @id @default(uuid()) @db.Uuid
  business_id String   @db.Uuid
  name        String
  is_active   Boolean  @default(true)
  deleted_at  DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([business_id, name])
  @@map("item_categories")
  @@schema("catalog")
}

model ItemCollection {
  id          String               @id @default(uuid()) @db.Uuid
  business_id String               @db.Uuid
  name        String
  is_active   Boolean              @default(true)
  deleted_at  DateTime?
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt
  items       ItemCollectionItem[]

  @@index([business_id, name])
  @@map("item_collections")
  @@schema("catalog")
}

model ItemCollectionItem {
  id            String         @id @default(uuid()) @db.Uuid
  business_id   String         @db.Uuid
  collection_id String         @db.Uuid
  variant_id    String         @db.Uuid
  is_active     Boolean        @default(true)
  deleted_at    DateTime?
  collection    ItemCollection @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  variant       ItemVariant    @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@index([business_id, collection_id])
  @@index([business_id, variant_id])
  @@map("item_collection_items")
  @@schema("catalog")
}

model ItemVariant {
  id            String                   @id @default(uuid()) @db.Uuid
  business_id   String                   @db.Uuid
  item_id       String                   @db.Uuid
  item          Item                     @relation(fields: [item_id], references: [id], onDelete: Cascade)
  collections   ItemCollectionItem[]
  // Active non-null SKUs are enforced unique per business by a partial unique index in SQL migrations.
  sku           String?
  barcode       String?
  name          String?
  metadata      Json?
  is_default    Boolean                  @default(false)
  is_active     Boolean                  @default(true)
  deleted_at    DateTime?
  option_values ItemVariantOptionValue[]

  @@map("item_variants")
  @@schema("catalog")
}

model ItemOption {
  id       String            @id @default(uuid()) @db.Uuid
  item_id  String            @db.Uuid
  item     Item              @relation(fields: [item_id], references: [id], onDelete: Cascade)
  name     String
  position Int               @default(0)
  values   ItemOptionValue[]

  @@unique([item_id, name])
  @@map("item_options")
  @@schema("catalog")
}

model ItemOptionValue {
  id             String                   @id @default(uuid()) @db.Uuid
  option_id      String                   @db.Uuid
  option         ItemOption               @relation(fields: [option_id], references: [id], onDelete: Cascade)
  value          String
  position       Int                      @default(0)
  variant_values ItemVariantOptionValue[]

  @@unique([option_id, value])
  @@map("item_option_values")
  @@schema("catalog")
}

model ItemVariantOptionValue {
  id              String          @id @default(uuid()) @db.Uuid
  variant_id      String          @db.Uuid
  variant         ItemVariant     @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  option_value_id String          @db.Uuid
  option_value    ItemOptionValue @relation(fields: [option_value_id], references: [id], onDelete: Cascade)

  @@unique([variant_id, option_value_id])
  @@map("item_variant_option_values")
  @@schema("catalog")
}
