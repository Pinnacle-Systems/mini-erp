enum SyncOperation {
  CREATE
  UPDATE
  DELETE
  PURGE

  @@schema("sync")
}

enum SyncMutationResultStatus {
  APPLIED
  REJECTED

  @@schema("sync")
}

model SyncMutationLog {
  id               String        @id @default(uuid()) @db.Uuid
  mutation_id      String        @unique
  tenant_id        String        @db.Uuid
  device_id        String
  user_id          String        @db.Uuid
  entity           String
  entity_id        String
  operation        SyncOperation
  payload          Json
  base_version     Int?
  client_timestamp DateTime
  server_timestamp DateTime      @default(now())
  result_status    SyncMutationResultStatus?
  result_summary   String?
  result_payload   Json?
  processed_at     DateTime?

  @@index([tenant_id, server_timestamp])
  @@index([tenant_id, processed_at])
  @@map("mutation_log")
  @@schema("sync")
}

model SyncChangeLog {
  id               String        @id @default(uuid()) @db.Uuid
  cursor           BigInt        @unique @default(autoincrement())
  tenant_id        String        @db.Uuid
  entity           String
  entity_id        String
  operation        SyncOperation
  data             Json
  server_version   Int
  server_timestamp DateTime      @default(now())

  @@index([tenant_id, cursor])
  @@index([tenant_id, entity, entity_id, server_version])
  @@map("change_log")
  @@schema("sync")
}
