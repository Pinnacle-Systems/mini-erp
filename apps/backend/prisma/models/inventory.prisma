enum UnitType {
  PCS
  KG
  M
  BOX

  @@schema("inventory")
}

enum ItemType {
  PRODUCT
  SERVICE

  @@schema("inventory")
}

model Item {
  id            String        @id @default(uuid()) @db.Uuid
  store_id      String        @db.Uuid
  item_type     ItemType      @default(PRODUCT)
  sku           String?
  name          String
  description   String
  unit          UnitType      @default(PCS)
  stock_ledgers StockLedger[]

  @@unique([store_id, sku])
  @@map("items")
  @@schema("inventory")
}

model Location {
  id            String        @id @default(uuid()) @db.Uuid
  store_id      String        @db.Uuid
  name          String
  stock_ledgers StockLedger[]

  @@map("locations")
  @@schema("inventory")
}

model StockLedger {
  id           String   @id @default(uuid()) @db.Uuid
  item_id      String   @db.Uuid
  item         Item     @relation(fields: [item_id], references: [id])
  location_id  String   @db.Uuid
  location     Location @relation(fields: [location_id], references: [id])
  quantity     Decimal  @db.Decimal(12, 3)
  reason       String
  reference_id String?

  created_at DateTime @default(now())

  @@map("stock_ledger")
  @@schema("inventory")
}
