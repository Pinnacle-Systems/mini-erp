model StockLedger {
  id           String   @id @default(uuid()) @db.Uuid
  business_id  String   @db.Uuid
  variant_id   String   @db.Uuid
  quantity     Decimal  @db.Decimal(12, 3)
  reason       String
  reference_id String?

  created_at DateTime @default(now())

  @@index([business_id, variant_id])
  @@map("stock_ledger")
  @@schema("inventory")
}
