enum DiscountRuleType {
  VOLUME
  BUNDLE
  DISCOUNT_CODE

  @@schema("pricing")
}

enum DiscountValueType {
  FIXED_AMOUNT
  PERCENTAGE

  @@schema("pricing")
}

model PriceBook {
  id               String                   @id @default(uuid()) @db.Uuid
  business_id      String                   @db.Uuid
  code             String?
  name             String
  default_currency String                   @db.VarChar(3)
  is_default       Boolean                  @default(false)
  is_active        Boolean                  @default(true)
  starts_at        DateTime?
  ends_at          DateTime?
  priority         Int                      @default(0)
  prices           ItemPrice[]
  customer_groups  PriceBookCustomerGroup[]
  rule_price_books DiscountRulePriceBook[]
  created_at       DateTime                 @default(now())
  updated_at       DateTime                 @updatedAt

  @@unique([business_id, code])
  @@index([business_id, is_default])
  @@map("price_books")
  @@schema("pricing")
}

model PriceBookCustomerGroup {
  id                String    @id @default(uuid()) @db.Uuid
  price_book_id     String    @db.Uuid
  customer_group_id String    @db.Uuid
  price_book        PriceBook @relation(fields: [price_book_id], references: [id], onDelete: Cascade)

  @@unique([price_book_id, customer_group_id])
  @@index([customer_group_id])
  @@map("price_book_customer_groups")
  @@schema("pricing")
}

model ItemPrice {
  id                String    @id @default(uuid()) @db.Uuid
  business_id       String    @db.Uuid
  price_book_id     String    @db.Uuid
  variant_id        String    @db.Uuid
  customer_group_id String?   @db.Uuid
  min_qty           Int       @default(1)
  max_qty           Int?
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @db.VarChar(3)
  is_active         Boolean   @default(true)
  starts_at         DateTime?
  ends_at           DateTime?
  priority          Int       @default(0)
  price_book        PriceBook @relation(fields: [price_book_id], references: [id], onDelete: Cascade)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([business_id, variant_id])
  @@index([customer_group_id])
  @@index([business_id, price_book_id, customer_group_id])
  @@index([business_id, is_active, starts_at, ends_at])
  @@map("item_prices")
  @@schema("pricing")
}

model DiscountRule {
  id                String                  @id @default(uuid()) @db.Uuid
  business_id       String                  @db.Uuid
  name              String
  description       String?
  rule_type         DiscountRuleType
  value_type        DiscountValueType
  value             Decimal                 @db.Decimal(12, 4)
  code              String?
  customer_group_id String?                 @db.Uuid
  min_qty           Int?
  max_qty           Int?
  max_discount      Decimal?                @db.Decimal(12, 2)
  is_active         Boolean                 @default(true)
  starts_at         DateTime?
  ends_at           DateTime?
  priority          Int                     @default(0)
  config            Json?
  rule_variants     DiscountRuleVariant[]
  rule_items        DiscountRuleItem[]
  rule_price_books  DiscountRulePriceBook[]
  created_at        DateTime                @default(now())
  updated_at        DateTime                @updatedAt

  @@index([business_id, rule_type])
  @@index([business_id, code])
  @@index([customer_group_id])
  @@index([business_id, is_active, starts_at, ends_at])
  @@map("discount_rules")
  @@schema("pricing")
}

model DiscountRuleVariant {
  id         String       @id @default(uuid()) @db.Uuid
  rule_id    String       @db.Uuid
  variant_id String       @db.Uuid
  rule       DiscountRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)

  @@unique([rule_id, variant_id])
  @@index([variant_id])
  @@map("discount_rule_variants")
  @@schema("pricing")
}

model DiscountRuleItem {
  id      String       @id @default(uuid()) @db.Uuid
  rule_id String       @db.Uuid
  item_id String       @db.Uuid
  rule    DiscountRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)

  @@unique([rule_id, item_id])
  @@index([item_id])
  @@map("discount_rule_items")
  @@schema("pricing")
}

model DiscountRulePriceBook {
  id            String       @id @default(uuid()) @db.Uuid
  rule_id       String       @db.Uuid
  price_book_id String       @db.Uuid
  rule          DiscountRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)
  price_book    PriceBook    @relation(fields: [price_book_id], references: [id], onDelete: Cascade)

  @@unique([rule_id, price_book_id])
  @@map("discount_rule_price_books")
  @@schema("pricing")
}
