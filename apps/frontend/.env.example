# Keep this file in sync with apps/frontend/.env.
# Keep cross-app values aligned with backend env files too.
# VITE_DEV_PROXY_TARGET should point to the same host and port as apps/backend/.env PORT.
# VITE_API_BASE_URL is read in src/lib/api.ts.
# Leave it blank in local dev so the frontend can fall back to VITE_DEV_PROXY_TARGET automatically.
# Set an absolute URL when the frontend is deployed separately from the backend.
VITE_API_BASE_URL=
# VITE_ANDROID_API_BASE_URL is read in src/lib/api.ts for Capacitor Android builds.
# Set an absolute HTTPS backend URL for signed Android builds.
VITE_ANDROID_API_BASE_URL=
# VITE_DEV_PROXY_TARGET is read in vite.config.ts for /api and /uploads during `vite dev`.
# It is also used as the frontend API base fallback during local development when VITE_API_BASE_URL is blank.
# If it is missing, Vite silently falls back to http://localhost:3000.
VITE_DEV_PROXY_TARGET=http://localhost:3000
# VITE_STORAGE_DIAGNOSTICS_MIN_QUOTA_MB sets the warning threshold for mobile storage telemetry.
VITE_STORAGE_DIAGNOSTICS_MIN_QUOTA_MB=100
