{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "android:assets": "capacitor-assets generate --android",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "android:run": "cap run android",
    "android:build:debug:win": "cap sync android && cd android && gradlew assembleDebug",
    "android:build:debug:unix": "cap sync android && cd android && ./gradlew assembleDebug",
    "android:prepare:release": "node ./scripts/prepare-android-release.mjs",
    "android:build:release:win": "pnpm run android:prepare:release && cap sync android && cd android && gradlew bundleRelease",
    "android:build:release:unix": "pnpm run android:prepare:release && cap sync android && cd android && ./gradlew bundleRelease",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.1.2",
    "@capacitor/network": "^7.0.4",
    "browser-image-compression": "^2.0.2",
    "dexie": "^4.3.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.574.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-easy-crop": "^5.5.6",
    "react-router-dom": "^7.9.4",
    "workbox-window": "^7.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^7.1.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.1.2",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.2.2",
    "vite-plugin-pwa": "^1.1.0"
  }
}