{
  "name": "mini-erp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "backend:dev": "turbo dev --filter=backend",
    "frontend:dev": "turbo dev --filter=frontend",
    "lint": "turbo run lint && pnpm lint:deps",
    "pwa:preview": "pnpm --filter frontend build && concurrently -k -n backend,frontend \"pnpm --filter backend dev\" \"pnpm --filter frontend preview\"",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs apps/frontend/src apps/backend/src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.3.8",
    "turbo": "^2.8.13"
  }
}
